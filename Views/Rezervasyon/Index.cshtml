@model List<RezerveMuzikWeb.Models.Rezervasyon>
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div style="background-color: #1a1a1a; padding: 40px; border-radius: 10px; border: 1px solid #333; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
                <div class="text-center mb-4">
                    <h3 style="color: white; font-weight: bold; text-shadow: 0 0 10px rgba(255,255,255,0.5);">Yeni Rezervasyon Talebi</h3>
                </div>

                <form action="/Rezervasyon/RezerveEt" method="post">
                    <div class="form-group" style="margin-bottom: 20px;">
                        <label style="color: #a0a0a0; font-size: 14px; margin-bottom: 10px; display: block;">Oda Seçimi (Oda ID)</label>
                        <input type="number" class="form-control" name="OdaId" placeholder="Örn: 1" required
                               style="background-color: #222; color: white; border: 1px solid #444; padding: 10px;" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group" style="margin-bottom: 20px;">
                            <label style="color: #a0a0a0; font-size: 14px; margin-bottom: 10px; display: block;">Başlangıç Tarihi ve Saati</label>
                            <input type="datetime-local" class="form-control" name="BaslangicZamani" required
                                   style="background-color: #222; color: white; border: 1px solid #444; padding: 10px;" />
                        </div>

                        <div class="col-md-6 form-group" style="margin-bottom: 30px;">
                            <label style="color: #a0a0a0; font-size: 14px; margin-bottom: 10px; display: block;">Bitiş Tarihi ve Saati</label>
                            <input type="datetime-local" class="form-control" name="BitisZamani" required
                                   style="background-color: #222; color: white; border: 1px solid #444; padding: 10px;" />
                        </div>
                    </div>

                    <button type="submit" class="boxed-btn3" style="width: 100%; text-align: center;">Rezervasyon Yap</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-xl-12">
            <h3 style="color: white; font-weight: bold; margin-bottom: 25px; text-shadow: 0 0 10px rgba(255,255,255,0.3);">Mevcut Rezervasyonlarım</h3>

            <table class="table table-dark table-striped mt-3">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Oda No</th>
                        <th>Başlangıç Zamanı</th>
                        <th>Bitiş Zamanı</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rez in Model)
                    {
                        <tr>
                            <td>@rez.Id</td>
                            <td>Oda @rez.OdaFkId</td>
                            <td>@rez.BaslangicTarihSaat.ToString("g")</td>
                            <td>@rez.BitisTarihSaat.ToString("g")</td>
                            <td><span style="color: #ff3500; font-weight: bold;">@rez.Durum</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

