@model List<RezerveMuzikWeb.Models.Rezervasyon>
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">

    <div style="background-color: #f8f9fa; padding: 30px; border-radius: 10px; margin-bottom: 40px;">
        <h3 style="color: black;">Yeni Rezervasyon Talebi</h3>
        <form method="post" action="/Rezervasyon/Ekle">
            <div class="row">
                <div class="col-md-4">
                    <label style="color: black;">Oda Seçimi (Oda ID)</label>
                    <input type="number" class="form-control" name="OdaFkId" required />
                </div>
                <div class="col-md-4">
                    <label style="color: black;">Başlangıç Tarihi ve Saati</label>
                    <input type="datetime-local" class="form-control" name="BaslangicTarihSaat" required />
                </div>
                <div class="col-md-4">
                    <label style="color: black;">Bitiş Tarihi ve Saati</label>
                    <input type="datetime-local" class="form-control" name="BitisTarihSaat" required />
                </div>
            </div>
            <button type="submit" class="boxed-btn3 mt-3">Rezervasyon Yap</button>
        </form>
    </div>

    <h3 style="color: white;">Mevcut Rezervasyonlarım</h3>
    <table class="table table-dark table-striped mt-3">
        <thead>
            <tr>
                <th>#ID</th>
                <th>Oda No</th>
                <th>Başlangıç Zamanı</th>
                <th>Bitiş Zamanı</th>
                <th>Durum</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rez in Model)
            {
                <tr>
                    <td>@rez.Id</td>
                    <td>Oda @rez.OdaFkId</td>
                    <td>@rez.BaslangicTarihSaat.ToString("g")</td>
                    <td>@rez.BitisTarihSaat.ToString("g")</td>
                    <td><span style="color: #ff3500; font-weight: bold;">@rez.Durum</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>