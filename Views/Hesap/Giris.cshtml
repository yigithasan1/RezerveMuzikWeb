@{
    ViewData["Title"] = "Sisteme Giriş";
}

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <div class="row justify-content-center">

        <div class="col-md-6 col-lg-5">

            <div style="background-color: #1a1a1a; padding: 40px; border-radius: 10px; border: 1px solid #333; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">

                <div class="text-center mb-4">
                    <h3 style="color: white; font-weight: bold;">Müzisyen Girişi</h3>
                    <p style="color: #a0a0a0;">Rezervasyon yapmak için hesabınıza giriş yapın.</p>
                </div>

                <form action="#" method="post">

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label style="color: white; margin-bottom: 10px;">E-Posta Adresi</label>
                        <input type="email" class="form-control" name="Email" placeholder="ornek@mail.com" required
                               style="background-color: #222; color: white; border: 1px solid #444; padding: 10px;" />
                    </div>

                    <div class="form-group" style="margin-bottom: 30px;">
                        <label style="color: white; margin-bottom: 10px;">Şifre</label>
                        <input type="password" class="form-control" name="Sifre" placeholder="******" required
                               style="background-color: #222; color: white; border: 1px solid #444; padding: 10px;" />
                    </div>

                    <button type="submit" class="boxed-btn3" style="width: 100%; text-align: center;">Giriş Yap</button>
                </form>

                <div class="text-center mt-4">
                    <p style="color: #a0a0a0; font-size: 14px;">
                        Henüz hesabınız yok mu?
                        <a href="#" style="color: #ff3500; font-weight: bold; text-decoration: underline;">Hemen Kayıt Ol</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>